{
  "manifest_version": 3,
  "name": "Drive Sidebar",
  "version": "1.0.0",
  "description": "Save any webpage as Markdown to Google Drive with one click",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Drive Sidebar",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "permissions": [
    "storage",
    "declarativeNetRequest",
    "scripting",
    "tabs",
    "identity",
    "downloads"
  ],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "637644398789-ijesnvmaar77mjfb9ravlgqkgotmnkm3.apps.googleusercontent.com",
    "scopes": ["https://www.googleapis.com/auth/drive.file"]
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_1",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["turndown.min.js", "save_to_drive.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
